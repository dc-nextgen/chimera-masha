# Yerel test DB kimligi. Bunu `.env.test` olarak KOPYALA ve doldur (.env.test gitignored).
# Kullanim:  set -a; . .env.test; set +a; ./masha-agent introspect
#
# go-mssqldb DSN formati:
#   sqlserver://KULLANICI:PAROLA@HOST:1433?database=VERITABANI
# Parolada ozel karakter varsa URL-encode et (@ -> %40, : -> %3A ...).
# Named instance:  sqlserver://KULLANICI:PAROLA@HOST/INSTANCE?database=VERITABANI
# TLS self-signed / local Express icin gerekiyorsa ekle:
#   &encrypt=disable                (sifreleme kapali — yalniz guvenli ag/test)
#   veya &encrypt=true&trustservercertificate=true
#
# ERISIM: bu Mac HOST:PORT'a ulasabilmeli (LAN-only ise VPN/tunel gerekir).

MASHA_DB_DSN='sqlserver://kullanici:parola@10.0.0.5:1433?database=IBSDB&encrypt=disable'

# Introspeksiyon icin manifest sart DEGIL; serve/test icin uretecegim manifest'i buraya koyacagim:
# MASHA_MANIFEST=./example/manifest.json
# MASHA_APP_TOKEN=test-token
# MASHA_SERVER_LABEL=masha-db
